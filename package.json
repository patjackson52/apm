{
  "name": "apm",
  "version": "0.1.0",
  "description": "Agent Project Manager \u2014 durable project-execution state CLI",
  "type": "module",
  "bin": {
    "apm": "dist/bin/apm.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/storage/schema.sql dist/storage/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "apm": "tsx src/bin/apm.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@apm/types": "file:packages/types",
    "zod": "3.24.1"
  }
}
